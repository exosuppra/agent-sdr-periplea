# ============================================================
#  Configuration de l'agent SDR autonome : copier en .env
# ============================================================

# --- IA : le cerveau de l'agent (OBLIGATOIRE) ---
# Cle a creer sur https://console.anthropic.com  (onglet API Keys)
ANTHROPIC_API_KEY=sk-ant-...
SDR_MODEL=claude-sonnet-4-6

# --- Mode des outils ---
# "mock" = bac a sable (faux prospects, faux agenda, faux CRM) : aucun compte requis
# "live" = vrais services (Unipile / Cal.com / HubSpot)
TOOLS_MODE=mock

# --- Acces LinkedIn via Unipile (mode live uniquement) ---
# Token : https://dashboard.unipile.com/access-tokens   DSN : tableau de bord
UNIPILE_API_KEY=
UNIPILE_DSN=
UNIPILE_ACCOUNT_ID=

# --- CRM HubSpot (mode live uniquement) ---
# Token d'app privee : Settings > Integrations > Private Apps
HUBSPOT_TOKEN=

# --- Recherche LinkedIn REELLE sans risque (Apify) ---
# Cherche de vrais profils publics ; la conversation reste simulee.
# Token : https://console.apify.com/account/integrations
APIFY_TOKEN=

# --- Enrichissement email OPTIONNEL (Hunter.io) ---
# Devine l'email pro a partir du nom + ecole. Vide = desactive (aucun appel).
# Cle : https://hunter.io (plan gratuit 25 recherches/mois). L'email est marque
# ESTIME (a confirmer) cote CRM, jamais traite comme un email confirme (RGPD).
HUNTER_API_KEY=

# --- Agenda Cal.com (mode live uniquement) ---
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
# Instance EU (compte cal.eu) : https://api.cal.eu/v2  | sinon laisser vide
CALCOM_BASE=https://api.cal.com/v2

# Ton email (pour les invitations d'agenda)
OWNER_EMAIL=quentin.duroy28@gmail.com
